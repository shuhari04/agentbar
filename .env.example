# Generate a long random value before exposing AgentBar to the internet.
AGENTBAR_DATABASE_URL=postgresql://agentbar:agentbar@db:5432/agentbar
AGENTBAR_TOKEN_SECRET=replace-with-a-long-random-secret
AGENTBAR_SESSION_SECRET=replace-with-a-different-long-random-secret
AGENTBAR_PUBLIC_ORIGIN=http://localhost:3000
AGENTBAR_AUTH_PROVIDER=guest
# OIDC mode only: issuer discovery URL, public client ID, optional client secret.
# AGENTBAR_AUTH_PROVIDER=oidc
# AGENTBAR_OIDC_ISSUER=https://issuer.example.com
# AGENTBAR_OIDC_CLIENT_ID=agentbar
# AGENTBAR_OIDC_CLIENT_SECRET=
AGENTBAR_DATA_DIR=/app/.data
AGENTBAR_DECISION_TIMEOUT_MS=30000
